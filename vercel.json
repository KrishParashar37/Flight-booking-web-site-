{
    "version": 2,
    "builds": [
        {
            "src": "Flight-master/capstone/wsgi.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb" }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/Flight-master/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "Flight-master/capstone/wsgi.py"
        }
    ]
}
